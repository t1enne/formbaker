{
  "compilerOptions": {
    "target": "es2023",
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "declaration": true
  },
  "exclude": ["node_modules", "dist", "packages/**/tests/**", "packages/**/*.spec.ts", "packages/**/*.spec.tsx"]
}
