{
  "name": "formbaker",
  "version": "0.1.0",
  "description": "Formbaker — dynamic form engine with dependency-based visibility and validation",
  "keywords": [
    "conditional-form",
    "dynamic-form",
    "form",
    "form-builder",
    "form-configurator",
    "schema",
    "validation"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nasrt/formbaker"
  },
  "files": [
    "dist/*.js",
    "dist/*.d.ts",
    "dist/src/"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./test-utils": {
      "types": "./dist/src/test-utils.d.ts",
      "default": "./dist/src/test-utils.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@standard-schema/spec": "^1.1.0"
  }
}
