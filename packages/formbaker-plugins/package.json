{
  "name": "@formbaker/plugins",
  "version": "0.1.0",
  "description": "Validation plugins for Formbaker (arktype, zod, class-validator)",
  "keywords": [
    "arktype",
    "class-validator",
    "form",
    "formbaker",
    "plugin",
    "validation",
    "zod"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nasrt/formbaker"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    "./arktype": {
      "types": "./dist/arktype/index.d.ts",
      "default": "./dist/arktype/index.js"
    },
    "./zod": {
      "types": "./dist/zod/index.d.ts",
      "default": "./dist/zod/index.js"
    },
    "./class-validator": {
      "types": "./dist/class-validator/index.d.ts",
      "default": "./dist/class-validator/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "arktype": "^2.2.1",
    "class-validator": "^0.15.1",
    "formbaker": "*",
    "reflect-metadata": "^0.2.2",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "arktype": "^2.2.0",
    "class-validator": ">=0.12.0",
    "formbaker": "*",
    "zod": "^4.4.0"
  },
  "peerDependenciesMeta": {
    "arktype": {
      "optional": true
    },
    "class-validator": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  }
}
