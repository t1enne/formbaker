{
  "name": "@formbaker/plugins",
  "version": "0.1.0",
  "description": "Validation plugins for Formbaker (arktype, zod)",
  "type": "module",
  "exports": {
    "./arktype": {
      "types": "./dist/arktype.d.ts",
      "default": "./dist/arktype.js"
    },
    "./zod": {
      "types": "./dist/zod.d.ts",
      "default": "./dist/zod.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "arktype": "^2.2.1",
    "formbaker": "*",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "arktype": "^2.2.0",
    "formbaker": "*",
    "zod": "^4.4.0"
  },
  "peerDependenciesMeta": {
    "arktype": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  }
}
